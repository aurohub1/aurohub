{
  "framework": "nextjs",
  "github": {
    "enabled": false
  },
  "crons": [
    {
      "path": "/api/cron?secret=${CRON_SECRET}",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/vault",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron/relatorio-mensal",
      "schedule": "0 8 1 * *"
    },
    {
      "path": "/api/cron/platform-updates",
      "schedule": "0 9 * * *"
    }
  ]
}
